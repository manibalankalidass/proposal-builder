{
  "name": "custom-form",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "kill:4200": "fuser -k 4200/tcp 2>/dev/null; lsof -ti tcp:4200 | xargs -r kill -9 2>/dev/null; exit 0",
    "prestart": "npm run kill:4200",
    "start": "ng serve --port 4200",
    "predev": "npm run kill:4200",
    "dev": "ng serve --port 4200",
    "preserve": "npm run kill:4200",
    "serve": "ng serve --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:custom-form": "node dist/custom-form/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.43.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
